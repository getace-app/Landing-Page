#!/bin/sh

branch="$(git symbolic-ref --short HEAD 2>/dev/null)"

if [ -z "$branch" ]; then
    exit 0
fi

if [ "$branch" = "main" ]; then
    exit 0
fi

if echo "$branch" | grep -qE '^[a-zA-Z]+/ACE-'; then
    exit 0
fi

echo ""
echo "ERROR: Branch name '$branch' does not match the required pattern."
echo "       Expected: <prefix>/ACE-<description>"
echo "       Examples: feature/ACE-123, fix/ACE-open-source, chore/ACE-cleanup"
echo ""

exit 1
